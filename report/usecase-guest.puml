@startuml usecase-guest
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome
skinparam defaultFontName Arial
skinparam usecase {
  BackgroundColor White
  BorderColor Black
}

actor "Khách" as Guest

rectangle "Nhóm use-case actor Khách" {
  usecase "UC-01\nĐăng ký tài khoản" as G1
  usecase "UC-02\nĐăng nhập và\nduy trì phiên" as G2
  usecase "UC-04\nKhôi phục mật khẩu" as G4
}

Guest --> G1
Guest --> G2
Guest --> G4
@enduml
