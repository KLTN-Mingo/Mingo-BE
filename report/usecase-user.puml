@startuml usecase-user
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome
skinparam defaultFontName Arial
skinparam usecase {
  BackgroundColor White
  BorderColor Black
}

actor "Người dùng" as User
actor "Gemini API" as Gemini

rectangle "Nhóm use-case actor Người dùng" {
  usecase "UC-03\nQuản lý 2FA" as U3
  usecase "UC-05\nQuản lý hồ sơ cá nhân" as U5
  usecase "UC-06\nTìm kiếm toàn cục" as U6
  usecase "UC-07\nQuản lý quan hệ\nngười dùng" as U7
  usecase "UC-08\nQuản lý bài viết" as U8
  usecase "UC-09\nTương tác với nội dung" as U9
  usecase "UC-10\nXem feed cá nhân hóa" as U10
  usecase "UC-11\nGiải thích thuật ngữ\nvăn hóa mạng" as U11
  usecase "UC-12\nNhận và quản lý\nthông báo" as U12
  usecase "UC-13\nNhắn tin và gọi thoại" as U13
  usecase "UC-14\nGửi báo cáo vi phạm" as U14
}

User --> U3
User --> U5
User --> U6
User --> U7
User --> U8
User --> U9
User --> U10
User --> U11
User --> U12
User --> U13
User --> U14
Gemini --> U11
@enduml
