@startuml usecase-admin
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome
skinparam defaultFontName Arial
skinparam usecase {
  BackgroundColor White
  BorderColor Black
}

actor "Quản trị viên" as Admin
actor "Gemini API" as Gemini

rectangle "Nhóm use-case actor Quản trị viên" {
  usecase "UC-15\nKiểm duyệt nội dung\nbằng AI" as A15
  usecase "UC-16\nQuản trị báo cáo\nvà nội dung" as A16
  usecase "UC-17\nQuản lý từ điển slang" as A17
  usecase "UC-18\nTheo dõi thống kê\nhệ thống" as A18
}

Admin --> A15
Admin --> A16
Admin --> A17
Admin --> A18
Gemini --> A15
@enduml
