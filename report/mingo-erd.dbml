Table users {
  _id string [pk]
  phoneNumber string
  email string
  passwordHash string
  name string
  bio string
  avatar string
  coverPhoto string
  role string
  verified boolean
  isBlocked boolean
  twoFactorEnabled boolean
  followersCount int
  followingCount int
  postsCount int
  createdAt datetime
  updatedAt datetime
}

Table userprofiles {
  _id string [pk]
  userId string [unique, not null]
  topicScores json
  hashtagScores json
  authorScores json
  interactionCount int
  preferredContentType string
  updatedAt datetime
}

Table follows {
  _id string [pk]
  followerId string [not null]
  followingId string [not null]
  followStatus string
  closeFriendStatus string
  closeFriendRequestedBy string
  createdAt datetime
  updatedAt datetime
}

Table posts {
  _id string [pk]
  userId string [not null]
  contentText text
  visibility string
  moderationStatus string
  aiToxicScore float
  aiHateSpeechScore float
  aiSpamScore float
  hotScore float
  topics json
  culturalTerms json
  reportCount int
  createdAt datetime
  updatedAt datetime
}

Table postmedia {
  _id string [pk]
  postId string [not null]
  userId string [not null]
  mediaType string
  mediaUrl string
  thumbnailUrl string
  orderIndex int
  likesCount int
  commentsCount int
}

Table comments {
  _id string [pk]
  postId string
  mediaId string
  userId string [not null]
  parentCommentId string
  originalCommentId string
  contentText text
  moderationStatus string
  likesCount int
  repliesCount int
  createdAt datetime
  updatedAt datetime
}

Table notifications {
  _id string [pk]
  userId string [not null]
  actorId string
  notificationType string
  entityType string
  entityId string
  isRead boolean
  isSeen boolean
  createdAt datetime
}

Table messageboxes {
  _id string [pk]
  senderId string
  receiverIds json
  adminIds json
  messageIds json
  groupName string
  category string
  createdAt datetime
  updatedAt datetime
}

Table messages {
  _id string [pk]
  boxId string [not null]
  createBy string [not null]
  text json
  contentId json
  readedId json
  visibility string
  createdAt datetime
  updatedAt datetime
}

Table reports {
  _id string [pk]
  reporterId string [not null]
  targetType string
  targetId string
  reason string
  description text
  status string
  reviewedBy string
  actionTaken string
  createdAt datetime
  updatedAt datetime
}

Table verificationtokens {
  _id string [pk]
  userId string
  identifier string
  channel string
  purpose string
  tokenHash string
  expiresAt datetime
  usedAt datetime
  attempts int
  createdAt datetime
}

Table slangentries {
  _id string [pk]
  term string
  aliases json
  regexPattern string
  category string
  isActive boolean
  reportCount int
  createdAt datetime
  updatedAt datetime
}

Table devicetokens {
  _id string [pk]
  userId string [not null]
  token string
  platform string
  deviceName string
  lastUsedAt datetime
}

Ref: userprofiles.userId - users._id
Ref: follows.followerId > users._id
Ref: follows.followingId > users._id
Ref: posts.userId > users._id
Ref: postmedia.postId > posts._id
Ref: postmedia.userId > users._id
Ref: comments.postId > posts._id
Ref: comments.mediaId > postmedia._id
Ref: comments.userId > users._id
Ref: comments.parentCommentId > comments._id
Ref: notifications.userId > users._id
Ref: notifications.actorId > users._id
Ref: messageboxes.senderId > users._id
Ref: messages.boxId > messageboxes._id
Ref: messages.createBy > users._id
Ref: reports.reporterId > users._id
Ref: verificationtokens.userId > users._id
Ref: devicetokens.userId > users._id
